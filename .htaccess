RewriteEngine On

# Allow direct access to static files
RewriteCond %{REQUEST_URI} ^/public/css/ [OR]
RewriteCond %{REQUEST_URI} ^/public/js/ [OR]
RewriteCond %{REQUEST_URI} ^/public/img/
RewriteRule ^ - [L]

# Redirect everything else to the entry point
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ public/index.php [L]
